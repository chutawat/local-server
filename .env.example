# Copy to `.env` and adjust if needed. ค่าพวกนี้ใช้ร่วมกันทุกโปรเจค.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_PORT=3306

# MongoDB
MONGO_USER=root
MONGO_PASSWORD=root
MONGO_PORT=27017

# Redis (เว้นว่าง = ไม่ตั้ง password)
REDIS_PASSWORD=
REDIS_PORT=6379

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# SQL Server (สำหรับ restore legacy .bak ก่อน migrate)
# SA password ต้องผ่าน complexity policy: >=8 ตัว มีตัวใหญ่/เล็ก/เลข/สัญลักษณ์
MSSQL_SA_PASSWORD=LocalServer!123
MSSQL_PID=Developer
MSSQL_PORT=1433
# โฟลเดอร์ host ที่จะ mount เป็น /backups ในคอนเทนเนอร์ (วาง .bak ที่นี่เพื่อ restore)
MSSQL_BACKUP_DIR=./sqlserver-backups

# Oracle 19c EE (dev DB สำหรับ RAOT/RRF — build จาก raot-oracle-server/19.3.0)
# path ไป build context (Oracle Dockerfile + DB home zip). override ได้ถ้า repo อยู่ที่อื่น
ORACLE_BUILD_CONTEXT=../RAOT/Source-3th/raot-oracle-server/19.3.0
ORACLE_PDB=rrfdb
ORACLE_PWD=Manager123
ORACLE_MEM=3000
ORACLE_PORT=1521
ORACLE_EM_PORT=5500

# SonarQube (shared static-analysis server — used by the va-scan skill)
# Web UI: http://localhost:${SONARQUBE_PORT}  (9000 is taken by MinIO)
SONARQUBE_PORT=9009
SONARQUBE_DB=sonarqube
# Filled automatically by the va-scan skill on first run (do not commit .env):
SONAR_ADMIN_PASSWORD=
SONAR_TOKEN=

# 9router (local AI router/proxy — dashboard + API ที่ http://localhost:${NINEROUTER_PORT})
# pin version (tag :latest ค้าง) — แก้ค่านี้แล้ว docker compose up -d ninerouter เพื่ออัปเดต
NINEROUTER_VERSION=0.5.40
NINEROUTER_PORT=20128
NINEROUTER_INITIAL_PASSWORD=123456
NINEROUTER_JWT_SECRET=change-me-local-dev
