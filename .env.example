# Copy to `.env` and adjust if needed. ค่าพวกนี้ใช้ร่วมกันทุกโปรเจค.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_PORT=5432

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=app
MYSQL_USER=app
MYSQL_PASSWORD=app
MYSQL_PORT=3306

# MongoDB
MONGO_USER=root
MONGO_PASSWORD=root
MONGO_PORT=27017

# Redis (เว้นว่าง = ไม่ตั้ง password)
REDIS_PASSWORD=
REDIS_PORT=6379

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
